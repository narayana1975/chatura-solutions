# Supabase Configuration
# Get these values from your Supabase project settings
# https://supabase.com/dashboard/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Your Supabase public anonymous key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key (REQUIRED if RLS is enabled on your database tables)
# This is used for server-side operations in API routes
# Get this from: Supabase Dashboard > Settings > API > Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
